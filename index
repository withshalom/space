<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galactic Invaders</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #111;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: white;
            font-family: 'Courier New', Courier, monospace;
            overflow: hidden;
        }
        canvas {
            background-color: #000;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.2);
            border: 2px solid #333;
        }
        #ui {
            position: absolute;
            top: 20px;
            text-align: center;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <canvas id="gameCanvas" width="800" height="600"></canvas>
    <div id="ui">
        <h2>Use LEFT/RIGHT arrows to move. SPACE to shoot.</h2>
    </div>

<script>
    const canvas = document.getElementById("gameCanvas");
    const ctx = canvas.getContext("2d");

    // Game State
    let score = 0;
    let level = 1;
    let isGameOver = false;
    let keys = {};

    // Input Handling
    window.addEventListener("keydown", (e) => { keys[e.code] = true; });
    window.addEventListener("keyup", (e) => { keys[e.code] = false; });

    // --- Background Stars ---
    const stars = [];
    for (let i = 0; i < 100; i++) {
        stars.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            speed: Math.random() * 2 + 0.5,
            size: Math.random() * 2
        });
    }

    function drawBackground() {
        ctx.fillStyle = "black";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "white";
        stars.forEach(star => {
            ctx.beginPath();
            ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
            ctx.fill();
            star.y += star.speed;
            if (star.y > canvas.height) {
                star.y = 0;
                star.x = Math.random() * canvas.width;
            }
        });
    }

    // --- Player ---
    const player = {
        x: canvas.width / 2 - 20,
        y: canvas.height - 50,
        width: 40,
        height: 30,
        speed: 5,
        cooldown: 0,
        draw() {
            ctx.fillStyle = "#00FFFF";
            ctx.beginPath();
            ctx.moveTo(this.x + this.width / 2, this.y);
            ctx.lineTo(this.x + this.width, this.y + this.height);
            ctx.lineTo(this.x + this.width / 2, this.y + this.height - 10);
            ctx.lineTo(this.x, this.y + this.height);
            ctx.closePath();
            ctx.fill();
        },
        update() {
            if (keys["ArrowLeft"] && this.x > 0) this.x -= this.speed;
            if (keys["ArrowRight"] && this.x + this.width < canvas.width) this.x += this.speed;
            
            if (this.cooldown > 0) this.cooldown--;
            
            if (keys["Space"] && this.cooldown === 0) {
                bullets.push({
                    x: this.x + this.width / 2 - 2.5,
                    y: this.y,
                    width: 5,
                    height: 15,
                    speed: 8
                });
                this.cooldown = 15; // Fire rate
            }
        }
    };

    // --- Bullets ---
    let bullets = [];
    function handleBullets() {
        ctx.fillStyle = "#FFFF00";
        for (let i = bullets.length - 1; i >= 0; i--) {
            let b = bullets[i];
            b.y -= b.speed;
            ctx.fillRect(b.x, b.y, b.width, b.height);
            
            // Remove off-screen bullets
            if (b.y < 0) {
                bullets.splice(i, 1);
            }
        }
    }

    // --- Enemies ---
    let enemies = [];
    let enemyDirection = 1;
    let enemySpeed = 1;
    let dropDistance = 20;

    function initEnemies() {
        enemies = [];
        let rows = 4 + Math.min(level, 3);
        let cols = 8 + Math.min(level, 4);
        enemySpeed = 1 + (level * 0.5);
        
        for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
                enemies.push({
                    x: 50 + c * 50,
                    y: 50 + r * 40,
                    width: 30,
                    height: 20
                });
            }
        }
    }

    function drawEnemies() {
        ctx.fillStyle = "#FF0055";
        enemies.forEach(e => {
            // Draw a basic alien shape
            ctx.fillRect(e.x, e.y, e.width, e.height);
            ctx.fillStyle = "#000";
            ctx.fillRect(e.x + 5, e.y + 5, 5, 5); // Left eye
            ctx.fillRect(e.x + 20, e.y + 5, 5, 5); // Right eye
            ctx.fillStyle = "#FF0055";
        });
    }

    function updateEnemies() {
        let hitEdge = false;
        
        enemies.forEach(e => {
            e.x += enemySpeed * enemyDirection;
            if (e.x <= 0 || e.x + e.width >= canvas.width) {
                hitEdge = true;
            }
            // Game Over if enemies reach the bottom
            if (e.y + e.height >= player.y) {
                isGameOver = true;
            }
        });

        if (hitEdge) {
            enemyDirection *= -1;
            enemies.forEach(e => {
                e.y += dropDistance;
            });
        }
    }

    // --- Collisions ---
    function checkCollisions() {
        for (let i = bullets.length - 1; i >= 0; i--) {
            let b = bullets[i];
            let hit = false;
            
            for (let j = enemies.length - 1; j >= 0; j--) {
                let e = enemies[j];
                
                // AABB Collision detection
                if (b.x < e.x + e.width &&
                    b.x + b.width > e.x &&
                    b.y < e.y + e.height &&
                    b.y + b.height > e.y) {
                    
                    enemies.splice(j, 1);
                    hit = true;
                    score += 10;
                    break;
                }
            }
            
            if (hit) {
                bullets.splice(i, 1);
            }
        }
    }

    // --- UI ---
    function drawText() {
        ctx.fillStyle = "white";
        ctx.font = "20px Courier New";
        ctx.fillText(`Score: ${score}`, 20, 30);
        ctx.fillText(`Level: ${level}`, canvas.width - 120, 30);

        if (isGameOver) {
            ctx.fillStyle = "red";
            ctx.font = "50px Courier New";
            ctx.textAlign = "center";
            ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2);
            ctx.font = "20px Courier New";
            ctx.fillStyle = "white";
            ctx.fillText("Press F5 to Restart", canvas.width / 2, canvas.height / 2 + 40);
        }
    }

    // --- Main Game Loop ---
    function gameLoop() {
        if (isGameOver) {
            drawText();
            return;
        }

        drawBackground();
        
        player.update();
        player.draw();
        
        handleBullets();
        
        if (enemies.length === 0) {
            level++;
            initEnemies();
            bullets = [];
        }
        
        updateEnemies();
        drawEnemies();
        
        checkCollisions();
        
        drawText();

        requestAnimationFrame(gameLoop);
    }

    // Start Game
    initEnemies();
    gameLoop();
</script>

</body>
</html>
